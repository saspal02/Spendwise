  "batchTestScript": {
    "description": "Run these in order to test the full CRUD flow",
    "steps": [
      "1. Create an expense (should return 201, balance decreases)",
      "2. Create an income (should return 201, balance increases)",
      "3. List all transactions (should return both transactions)",
      "4. Update transaction #1 (should return 200 with updated fields)",
      "5. Delete transaction #1 (should return 200)",
      "6. List again (should show only remaining transactions)",
      "7. Try expense over balance (should fail with 400)"
    ]
  }
